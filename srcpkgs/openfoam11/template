# Template file for 'openfoam11'
pkgname=openfoam11
majorVersion=11
minorVersion=20240612
version=${majorVersion}.${minorVersion}
revision=1
build_style=""
configure_args=""
hostmakedepends="wget"
makedepends="openmpi-devel flex base-devel openmpi"
depends="openmpi libboost_thread flex openmpi gnuplot"
short_desc="OpenFOAM is a free, open source computational fluid dynamics (CFD) software package released by the OpenFOAM Foundation"
maintainer="muez <muezabdalla777@gmail.com>"
license="GPL-3.0"
homepage="https://www.openfoam.org/"
distfiles="http://dl.openfoam.org/source/${version}
http://dl.openfoam.org/third-party/${majorVersion}"
checksum="674a1039e5e11e49504ef163eafe659f32bea74e325c9bab7bc556c3c882915a
 7cbe362c48a0d668a9ce7c955d852ef78291b198be75fc53bbe11f9ca022c532"
python_version=3

do_fetch() {
	mkdir -p $wrksrc
	cd $wrksrc
	wget ${distfiles}
}
do_extract() {
	vtar -xf "${majorVersion}.${minorVersion}"
	vtar -xf "${majorVersion}"
}
post_extract() {
	mv "OpenFOAM-${majorVersion}-${minorVersion}" "OpenFOAM-${majorVersion}"
	mv "ThirdParty-${majorVersion}-version-${majorVersion}" "OpenFOAM-${majorVersion}/thirdparty"
}
do_patch() {
	# patch the aliases file
	sed -i '78d' "OpenFOAM-${majorVersion}/etc/config.sh/aliases"
	sed -i '77aelif command -V wmRefresh 2> /dev/null\nthen' "OpenFOAM-${majorVersion}/etc/config.sh/aliases"

	# patch the bashrc to accomodate for renaming ThirdParty -> thirdparty
	sed -i 's;export WM_THIRD_PARTY_DIR=$WM_PROJECT_INST_DIR/ThirdParty-$WM_PROJECT_VERSION;export WM_THIRD_PARTY_DIR=$WM_PROJECT_INST_DIR/$WM_PROJECT-$WM_PROJECT_VERSION/thirdparty;' "OpenFOAM-${majorVersion}/etc/bashrc"
}
do_build() {
	export HOME="/builddir"
	mkdir -p "$HOME/.OpenFOAM"
	echo "export ParaView_TYPE=none" > $HOME/.OpenFOAM/prefs.sh
	cd "OpenFOAM-${majorVersion}"
	source ./etc/bashrc
	./Allwmake -j ${makejobs}
}
do_install() {
	mkdir ${PKGDESTDIR}/opt/
	mv *-${majorVersion} ${PKGDESTDIR}/opt/
}
