# Template file for 'openfoam-dev'
pkgname=openfoam-dev
version="$(date +%Y%m%d)"
revision=1
hostmakedepends="wget"
makedepends="openmpi-devel flex base-devel openmpi"
depends="openmpi libboost_thread flex openmpi gnuplot"
short_desc="OpenFOAM is a free, open source computational fluid dynamics (CFD) software package released by the OpenFOAM Foundation"
maintainer="muez <muezabdalla777@gmail.com>"
license="GPL-3.0"
homepage="https://www.openfoam.org/"
distfiles="https://codeload.github.com/OpenFOAM/OpenFOAM-dev/zip/refs/heads/master
 https://codeload.github.com/OpenFOAM/ThirdParty-dev/zip/refs/heads/master"
python_version=3

do_fetch() {
	mkdir -p $wrksrc
	cd $wrksrc
	wget ${distfiles}
}
do_extract() {
	vtar -xf "master"
	vtar -xf "master.1"
}
post_extract() {
	mv "OpenFOAM-dev-master" "OpenFOAM-dev"
	mv "ThirdParty-dev-master" "OpenFOAM-dev/thirdparty"
}
do_patch() {
	# patch the openmpi file
	sed -i '46d' "OpenFOAM-dev/etc/config.sh/mpi"
	sed -i "46alibDir=\`mpicc --showme:link | sed -e \'s/.*\\\(-L\\\|-Wl,-rpath=\\\|-Wl,-rpath,\\\|-Wl,-rpath -Wl,\\\)\\\([^ ]*\\\).*/\\\2/\'\`" "OpenFOAM-dev/etc/config.sh/mpi"

	# patch the bashrc to accomodate for renaming ThirdParty -> thirdparty
	sed -i 's/export WM_THIRD_PARTY=ThirdParty/export WM_THIRD_PARTY=thirdparty/' "OpenFOAM-dev/etc/bashrc"
	sed -i 's;export WM_THIRD_PARTY_DIR=$WM_PROJECT_INST_DIR/$WM_THIRD_PARTY-$WM_PROJECT_VERSION;export WM_THIRD_PARTY_DIR=$WM_PROJECT_INST_DIR/$WM_PROJECT-$WM_PROJECT_VERSION/$WM_THIRD_PARTY;' "OpenFOAM-dev/etc/bashrc"
}
do_build() {
	export HOME="/builddir"
	mkdir -p "$HOME/.OpenFOAM"
	echo "export ParaView_TYPE=none" > $HOME/.OpenFOAM/prefs.sh
	cd "OpenFOAM-dev"
	source ./etc/bashrc || return 0
	./Allwmake -j ${makejobs}
}
do_install() {
	mkdir ${PKGDESTDIR}/opt/
	mv *-dev ${PKGDESTDIR}/opt/
}
